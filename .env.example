# ═══════════════════════════════════════════════════════════════════════════
# InventoryMS — Required Environment Variables
# Copy this file to .env and fill in all values before running docker-compose.
# ═══════════════════════════════════════════════════════════════════════════

# Database
DB_USER=
DB_PASS=

AUTH_DB_NAME=authdb
INVENTORY_DB_NAME=inventorydb
NOTIFICATION_DB_NAME=notificationdb
SUPPLIER_DB_NAME=supplierdb

AUTH_DB_PORT=3307
INVENTORY_DB_PORT=3308
NOTIFICATION_DB_PORT=3309
SUPPLIER_DB_PORT=3310

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=

# Cookies — set true in production (HTTPS only)
COOKIE_SECURE=false

# Email — leave blank to receive OTPs in Docker logs during development
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ALERT_RECIPIENTS=

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=inventory-images

# Service ports
AUTH_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
REPORTING_SERVICE_PORT=8084
SUPPLIER_SERVICE_PORT=8085
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
FRONTEND_PORT=3000
